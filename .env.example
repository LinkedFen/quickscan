# Quick Scan Configuration
# Copy this file to .env and fill in the values

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────

# Email address shown / pre-filled in the frontend notification form (optional)
# The app will work without this configured
VITE_NOTIFICATION_EMAIL=

# ─── Backend Serverless Functions ────────────────────────────────────────────
# Set these in your Vercel Dashboard or Netlify Environment Variables UI.
# Never commit real values to source control.

# Email address that receives completed scan results
NOTIFICATION_EMAIL=

# Sender email address (must be verified with your email provider)
FROM_EMAIL=

# ─── SendGrid (api/quickscan-notify.js) ──────────────────────────────────────
# Obtain from https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=

# ─── Resend (api/quickscan-notify-resend.js) ─────────────────────────────────
# Obtain from https://resend.com/api-keys  (free tier: 100 emails/day)
RESEND_API_KEY=
