# Email Notification Configuration
# Copy this file to .env (for local development) and fill in your values
# For production (Netlify/Vercel), set these in your hosting platform's dashboard

# The email address that will receive quick scan notifications
NOTIFICATION_EMAIL=f.zwaans@supplyvalue.nl

# SendGrid API Key (get from https://sendgrid.com)
SENDGRID_API_KEY=your-sendgrid-api-key-here

# Verified sender email address (must be verified in SendGrid)
FROM_EMAIL=noreply@yourdomain.com
